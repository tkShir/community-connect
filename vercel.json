{
  "version": 2,
  "buildCommand": "npm run build:vercel",
  "outputDirectory": "dist/public",
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/index.cjs" },
    { "source": "/login",      "destination": "/api/index.cjs" },
    { "source": "/logout",     "destination": "/api/index.cjs" },
    { "source": "/callback",   "destination": "/api/index.cjs" },
    { "source": "/:path*",     "destination": "/index.html"   }
  ]
}
